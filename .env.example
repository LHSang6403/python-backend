# App
APP_NAME=python-backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=python_backend

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# JWT
JWT_SECRET_KEY=super-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# PASETO
PASETO_SECRET_KEY=change-me-32-bytes-exactly!12345
PASETO_ACCESS_TOKEN_EXPIRE_MINUTES=30
PASETO_REFRESH_TOKEN_EXPIRE_DAYS=7

# Stock Cache
STOCK_CACHE_TTL=300

# Rate Limiting
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_WRITE_PER_MINUTE=30
RATE_LIMIT_READ_PER_MINUTE=60

# External REST API
EXTERNAL_API_BASE_URL=https://api.example.com
EXTERNAL_API_KEY=your-api-key
EXTERNAL_API_TIMEOUT=30
